# ═══════════════════════════════════════════════════════════════
# ADRYRANCH — .htaccess OFICIAL (API CONFIGURADA + BLINDADO)
# ═══════════════════════════════════════════════════════════════

DirectoryIndex index.html index.php
Options -Indexes

# Permiso base para archivos estáticos públicos del ecosistema
Require all granted

# ── Bloqueo de archivos ocultos y de configuración de base ───────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(^\.htaccess$|^\.htpasswd$|\.ini$|\.env$|\.sql$)">
    Require all denied
</FilesMatch>

# ── Bloqueo estricto de carpetas estructurales y de control ─────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^knowledge(/.*)?$ - [F,L]
    RewriteRule ^core(/.*)?$      - [F,L]
    RewriteRule ^\.git            - [F,L]
    RewriteRule ^\.github         - [F,L]
</IfModule>

# ── Protección de PHP por defecto ───────────────────────────────
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# ── EXCEPCIONES: Endpoints autorizados para correr en el servidor ──
# Permitimos index, login y absolutamente todo lo que viva en la carpeta /api/
<FilesMatch "^(index|login)\.php$">
    Require all granted
</FilesMatch>

# Habilitar acceso de ejecución exclusivo a los endpoints de nuestra API
# Sin "^" al inicio: en local XAMPP la URI real es /AdryRanch/api/...
# (subcarpeta), mientras que en producción el docroot ya es la carpeta
# del proyecto y la URI es /api/... — esta forma cubre ambos casos.
<If "%{REQUEST_URI} =~ m#/api/.*\.php$#">
    Require all granted
</If>

# ── Headers de seguridad Nivel Militar (Mandamiento 2) ───────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

ErrorDocument 403 "Acceso denegado perimetral — AdryRanch."
ErrorDocument 404 "Recurso no encontrado."