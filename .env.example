; Plantilla pública — sin credenciales reales. Copiar a .env y rellenar.
; AdryRanch usa conexión remota forzada (ver CLAUDE.md §9.5): DB_HOST
; NUNCA debe ser "localhost" en este proyecto.

APP_ENV=local
APP_URL="http://localhost/AdryRanch"
ALLOWED_ORIGINS=http://localhost,https://tu-dominio-de-produccion.com

DB_HOST="host-remoto-del-hosting"
DB_NAME="nombre_base_datos"
DB_USER="usuario_base_datos"
DB_PASS=

SMTP_HOST="smtp.tu-dominio.com"
SMTP_PORT=465
SMTP_USER="correo@tu-dominio.com"
SMTP_PASS=
SMTP_SECURE=ssl

; Token de diagnóstico (api/test_conexiones.php)
TEST_TOKEN="cambia-este-valor"
; Token de un solo uso para el seeder (api/crear_usuarios_iniciales.php)
SETUP_TOKEN="cambia-este-valor-tambien"
